#!/usr/bin/env bash
# claude-autonomous — engage/disengage the autonomous loop + watchdog for the
# CURRENT project directory.
#
#   claude-autonomous on  ["<resume prompt>"]   # arm: Stop-driver loops, watchdog resurrects
#   claude-autonomous off                        # disarm
#   claude-autonomous status                     # show state
#
# Arming writes a project-local `.autonomous` marker (read by the Stop-hook
# driver) and registers the project with the launchd watchdog so a rate-limited
# / crashed session is relaunched after ~2 minutes.

set -euo pipefail
REGISTRY="$HOME/.claude/.autonomous-registry"
proj="$(pwd)"
# Prefer git toplevel as the project root.
top="$(git -C "$proj" rev-parse --show-toplevel 2>/dev/null || true)"
[ -n "$top" ] && proj="$top"

cmd="${1:-status}"

ensure_gitignore() {
  local gi="$proj/.gitignore"
  for pat in ".autonomous" ".autonomous-direction" ".autonomous-heartbeat" ".autonomous-prompt" ".autonomous-halt" ".autonomous.log" ".autonomous.pid"; do
    if [ -f "$gi" ] && ! grep -qxF "$pat" "$gi" 2>/dev/null; then echo "$pat" >> "$gi"; fi
    [ -f "$gi" ] || printf '%s\n' "$pat" >> "$gi"
  done
}

case "$cmd" in
  on)
    touch "$proj/.autonomous"
    rm -f "$proj/.autonomous-halt"   # arm fresh, not halted
    date +%s > "$proj/.autonomous-heartbeat"
    if [ "${2:-}" != "" ]; then
      printf '%s\n' "$2" > "$proj/.autonomous-prompt"
    elif [ ! -f "$proj/.autonomous-prompt" ]; then
      cat > "$proj/.autonomous-prompt" <<'EOF'
Resume autonomous work on this project. Mode: AUTONOMOUS OPERATION.
Run /gsd-progress to orient, then the self-driving loop (ORIENT→PRIORITIZE→EXECUTE→RECORD→LOOP).
If a team exists, re-attach and keep pinging teammates — do not let the orchestrator sleep.
A rate limit is NOT completion: back off and resume. Do not ask me questions — research and decide.
Stop ONLY by writing a line starting with "AUTONOMOUS-HALT:" (work complete or a stop-and-ask condition).
EOF
    fi
    mkdir -p "$(dirname "$REGISTRY")"
    touch "$REGISTRY"
    grep -qxF "$proj" "$REGISTRY" || echo "$proj" >> "$REGISTRY"
    ensure_gitignore
    echo "✅ autonomous ON for: $proj"
    echo "   marker .autonomous + registered with watchdog (relaunch ~2min after a rate-limit fall)."
    echo "   prompt: $proj/.autonomous-prompt   (edit to customize the resume brief)"
    ;;
  direction)
    # Like `on`, plus authorize the agent to CHOOSE the product direction itself
    # and record progress to the demo each cycle. "Needs direction" stops being a halt.
    touch "$proj/.autonomous" "$proj/.autonomous-direction"
    rm -f "$proj/.autonomous-halt"
    date +%s > "$proj/.autonomous-heartbeat"
    if [ "${2:-}" != "" ]; then
      printf '%s\n' "$2" > "$proj/.autonomous-prompt"
    else
      cat > "$proj/.autonomous-prompt" <<'EOF'
Develop this project autonomously and CHOOSE THE DIRECTION YOURSELF (you are authorized — do not ask me which).
Mode: AUTONOMOUS OPERATION + DIRECTION-AUTONOMY. Spine: GSD (mode yolo).
Loop: /gsd-progress to orient → if no clear next item, pick the HIGHEST-VALUE product direction by the rubric
((Value×Reach)/Effort, security-first) and commit to it → plan→build→verify→secure→ship (atomic commits) → record.
Periodically RECORD PROGRESS TO THE DEMO: append to DEMO.md (timestamp, chosen direction, unit shipped, result/metric,
commit SHA; screenshot path if UI) after each shipped unit, and refresh the runnable demo if the project has one.
Team from archetypes only; orchestrator never sleeps, pings the team, TeamDeletes finished teams.
Security: read ~/.claude/SECURITY.md before auth/payments/PII work; backend is source of truth. Decide craft/technical
choices yourself (research, try, measure, iterate). A rate limit / partial answer is NOT completion — back off and continue.
Stop ONLY via 'AUTONOMOUS-HALT:' when all valuable work across every direction is exhausted, or a true user-only condition
(security trade-off, irreversible deletion, public-API change, budget). "Needs business direction" is NOT a stop — you choose.
EOF
    fi
    mkdir -p "$(dirname "$REGISTRY")"; touch "$REGISTRY"
    grep -qxF "$proj" "$REGISTRY" || echo "$proj" >> "$REGISTRY"
    ensure_gitignore
    echo "🧭 autonomous DIRECTION mode ON for: $proj"
    echo "   agent will choose & drive the direction itself and log progress to DEMO.md."
    echo "   prompt: $proj/.autonomous-prompt"
    ;;
  off)
    rm -f "$proj/.autonomous" "$proj/.autonomous-direction" "$proj/.autonomous-heartbeat" "$proj/.autonomous-halt"
    if [ -f "$REGISTRY" ]; then grep -vxF "$proj" "$REGISTRY" > "$REGISTRY.tmp" 2>/dev/null || true; mv "$REGISTRY.tmp" "$REGISTRY" 2>/dev/null || true; fi
    echo "🛑 autonomous OFF for: $proj"
    ;;
  status)
    if [ -f "$proj/.autonomous" ]; then
      read -r hb _ < "$proj/.autonomous-heartbeat" 2>/dev/null; : "${hb:=0}"
      age=$(( $(date +%s) - hb ))
      mode="ON"; [ -f "$proj/.autonomous-direction" ] && mode="ON (direction-autonomy)"
      halted=""; [ -f "$proj/.autonomous-halt" ] && halted="  [HALTED — waiting for your message]"
      echo "$mode  $proj  (heartbeat ${age}s ago)$halted"
    else
      echo "OFF $proj"
    fi
    echo "--- registry ---"; [ -f "$REGISTRY" ] && cat "$REGISTRY" || echo "(empty)"
    ;;
  *) echo "usage: claude-autonomous on|direction|off|status [\"prompt/goal\"]"; exit 1 ;;
esac
